import numpy as np
import matplotlib.pyplot as plt

from tensorflow.keras.datasets import cifar10
from tensorflow.keras.layers import Input, Dense, Flatten, Reshape, Conv2D, MaxPooling2D
from tensorflow.keras.models import Model, Sequential
from tensorflow.keras.optimizers import Adam

from sklearn.svm import SVC
from sklearn.metrics import accuracy_score

# -----------------------------
# Fix randomness for reproducibility
# -----------------------------

np.random.seed(42)

# -----------------------------
# Load Dataset
# -----------------------------

(trainX, trainY), (testX, testY) = cifar10.load_data()

trainX = trainX[:5000]
trainY = trainY[:5000]

testX = testX[:1000]
testY = testY[:1000]

trainX = trainX / 255.0
testX = testX / 255.0

print("Training samples:", trainX.shape)
print("Testing samples:", testX.shape)

# -----------------------------
# Autoencoder for Compression
# -----------------------------

input_layer = Input(shape=(32,32,3))

flatten_layer = Flatten()(input_layer)

compressed_layer = Dense(128, activation='relu')(flatten_layer)

reconstruction = Dense(32*32*3, activation='sigmoid')(compressed_layer)
reconstruction = Reshape((32,32,3))(reconstruction)

auto_model = Model(input_layer, reconstruction)

feature_model = Model(input_layer, compressed_layer)

auto_model.compile(
    optimizer=Adam(),
    loss="mse"
)

auto_model.fit(
    trainX,
    trainX,
    epochs=3,
    batch_size=256,
    shuffle=True,
    verbose=0
)

print("Compression model trained")

# -----------------------------
# Extract Features
# -----------------------------

train_feat = feature_model.predict(trainX)
test_feat = feature_model.predict(testX)

print("Feature dimension:", train_feat.shape)

# -----------------------------
# CNN Classifier
# -----------------------------

cnn_model = Sequential([
    Input(shape=(32,32,3)),

    Conv2D(16,(3,3),activation='relu'),
    MaxPooling2D(),

    Conv2D(32,(3,3),activation='relu'),
    MaxPooling2D(),

    Flatten(),

    Dense(64,activation='relu'),
    Dense(10,activation='softmax')
])

cnn_model.compile(
    optimizer=Adam(),
    loss="sparse_categorical_crossentropy",
    metrics=["accuracy"]
)

cnn_model.fit(
    trainX,
    trainY,
    epochs=3,
    batch_size=128,
    verbose=0
)

cnn_accuracy = cnn_model.evaluate(testX, testY, verbose=0)[1]

print("Accuracy using CNN:", cnn_accuracy)

# -----------------------------
# SVM Classifier
# -----------------------------

svm_model = SVC(kernel="linear")

svm_model.fit(train_feat, trainY.ravel())

svm_pred = svm_model.predict(test_feat)

svm_accuracy = accuracy_score(testY, svm_pred)

print("Accuracy using SVM:", svm_accuracy)

# -----------------------------
# Image Reconstruction Display
# -----------------------------

reconstructed_imgs = auto_model.predict(testX[:10])

plt.figure(figsize=(10,4))

for i in range(5):

    plt.subplot(2,5,i+1)
    plt.imshow(testX[i])
    plt.title("Input")
    plt.axis("off")

    plt.subplot(2,5,i+6)
    plt.imshow(reconstructed_imgs[i])
    plt.title("Output")
    plt.axis("off")

plt.show()

# -----------------------------
# Accuracy Comparison Plot
# -----------------------------

models = ["CNN Model", "SVM Model"]
scores = [cnn_accuracy, svm_accuracy]

plt.bar(models, scores)

plt.ylabel("Accuracy Score")
plt.title("Classifier Performance Comparison")

plt.show()

print("\nModel Performance Summary")
print("-----------------------------")
print("CNN Accuracy:", cnn_accuracy)
print("SVM Accuracy:", svm_accuracy)



